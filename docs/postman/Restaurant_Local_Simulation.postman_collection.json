  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "adminEmail", "value": "admin@restaurant.local" },
    { "key": "adminPassword", "value": "ChangeMeNow123!" },
    { "key": "hubtelCallbackSecret", "value": "replace_with_your_HUBTEL_CALLBACK_SECRET" },
    { "key": "customerAName", "value": "Kwame Mensah" },
    { "key": "customerAPhone", "value": "233540000111" },
    { "key": "customerBName", "value": "Ama Boateng" },
    { "key": "customerBPhone", "value": "233240000222" }
  ],
  "item": [
    {
      "name": "1. Init (Menu + Admin Login)",
      "item": [
        {
          "name": "Get Public Menu",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/menu"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Menu request succeeded', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json().data || [];",
                  "pm.collectionVariables.set('itemA', data[0]?.id || '');",
                  "pm.collectionVariables.set('itemB', data[6]?.id || data[0]?.id || '');",
                  "pm.collectionVariables.set('itemC', data[12]?.id || data[0]?.id || '');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Admin CSRF Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/auth/csrf-token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CSRF token request succeeded', function () { pm.response.to.have.status(200); });",
                  "const token = pm.response.json().csrfToken;",
                  "pm.collectionVariables.set('csrfToken', token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-csrf-token", "value": "{{csrfToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login succeeded', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Create 6 Orders (3 each for 2 customers)",
