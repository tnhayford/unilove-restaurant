    {
      "name": "3. Simulate Paid Hubtel Callbacks",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const secret = pm.collectionVariables.get('hubtelCallbackSecret');",
              "if (!secret || secret.startsWith('replace_')) {",
              "  throw new Error('Set hubtelCallbackSecret in collection variables first.');",
              "}",
              "const raw = pm.request.body?.raw || '';",
              "const resolved = pm.variables.replaceIn(raw);",
              "const signature = CryptoJS.HmacSHA256(resolved, secret).toString(CryptoJS.enc.Hex);",
              "pm.collectionVariables.set('hubtelSignature', signature);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "item": [
        {
          "name": "Callback A1 Paid",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-hubtel-signature", "value": "{{hubtelSignature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ResponseCode\": \"0000\",\n  \"Message\": \"success\",\n  \"Data\": {\n    \"ClientReference\": \"{{orderA1Ref}}\",\n    \"TransactionId\": \"txn-{{orderA1Ref}}\",\n    \"ExternalTransactionId\": \"ext-{{orderA1Ref}}\",\n    \"Amount\": 120.00,\n    \"Charges\": 2.00,\n    \"AmountAfterCharges\": 118.00,\n    \"AmountCharged\": 120.00\n  }\n}"
            },
            "url": "{{baseUrl}}/api/payments/hubtel/callback"
