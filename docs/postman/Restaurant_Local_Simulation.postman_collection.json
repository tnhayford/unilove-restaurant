          "name": "Create Order A1 (Pickup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{customerAPhone}}\",\n  \"fullName\": \"{{customerAName}}\",\n  \"deliveryType\": \"pickup\",\n  \"items\": [\n    { \"itemId\": \"{{itemA}}\", \"quantity\": 2 },\n    { \"itemId\": \"{{itemB}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "pm.collectionVariables.set('orderA1Id', data.id);",
                  "pm.collectionVariables.set('orderA1Ref', data.clientReference);"
